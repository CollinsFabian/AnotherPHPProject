{
    "name": "collinsfabian/another-php-project",
    "description": "A simple PHP framework",
    "type": "project",
    "license": "MIT",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Collins Fabian",
            "email": "alphaalive22@gmail.com"
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/CollinsFabian/AnotherPHPProject.git"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "urchmann/zquery": "*",
        "ext-pdo": "*",
        "ext-mbstring": "*"
    },
    "autoload": {
        "files": [
            "core/helpers.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Core\\": "core/"
        }
    }
}