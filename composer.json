{
    "name": "zi/ziro",
    "description": "Ziro Framework: Ziro friction, Maximum velocity",
    "keywords": ["php, php framework, fast api, api, speed, quick, router"],
    "type": "project",
    "license": "MIT",
    "version": "0.0.13",
    "authors": [
        {
            "name": "Collins Fabian",
            "email": "alphaalive22@gmail.com"
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/CollinsFabian/Ziro.git"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "zi/zquery": "dev-main",
        "ext-pdo": "*",
        "ext-mbstring": "*"
    },
    "autoload": {
        "files": [
            "core/helpers.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Core\\": "core/"
        }
    }
}